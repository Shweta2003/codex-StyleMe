{
  "name": "ai-fit-stylist-demo",
  "version": "0.1.0",
  "description": "Scratch prototype for an AI fashion assistant with static demo images, a static product catalog, heuristic fit matching, and optional OpenAI Agents SDK integration.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:client": "node scripts/export-public-data.js && node scripts/export-public-config.js",
    "export-data": "node scripts/export-public-data.js",
    "export-config": "node scripts/export-public-config.js",
    "smoke": "node scripts/smoke-server.js",
    "test": "node --test src/recommendationEngine.test.js"
  },
  "dependencies": {
    "@openai/agents": "latest",
    "zod": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
